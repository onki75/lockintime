{
  "name": "lockintime",
  "version": "0.1.0",
  "description": "日本語特化のサイトブロッカー Chrome拡張",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:adult-filter": "npx tsx scripts/build-adult-filter.ts",
    "build:functions": "npm run build --prefix functions",
    "preview": "vite preview",
    "test": "vitest run",
    "test:functions": "npm test --prefix functions",
    "test:all": "npm test && npm run test:functions"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
