{
  "manifest_version": 3,
  "name": "LockInTime - サイトブロッカーで集中モード",
  "version": "0.1.0",
  "description": "日本語特化のサイトブロッカー。YouTube・X・漫画サイトをブロックして集中時間を確保。スクリーンタイムをPCでも管理。",
  "default_locale": "ja",
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
